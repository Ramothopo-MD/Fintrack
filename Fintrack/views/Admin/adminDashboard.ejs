<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - FinTrack</title>

  <!-- Bootstrap & Chart.js -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

  <style>
    :root {
      --primary: #003366;
      --primary-light: #004080;
      --primary-dark: #002855;
      --success: #198754;
      --danger: #dc3545;
      --warning: #ffc107;
      --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.08);
    }
    body {
      background-color: #f4f7fc;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
    }
    .navbar-custom { background-color: var(--primary); }
    .sidebar { background: var(--primary-dark); color: #fff; }
    .sidebar a { color: #cbd5e0; display: block; padding: 12px 18px; text-decoration: none; border-radius: 6px; }
    .sidebar a.active, .sidebar a:hover { background: var(--primary-light); color: #fff; }
    .card { border-radius: 12px; border: none; box-shadow: var(--card-shadow); }
    .card:hover { transform: translateY(-3px); transition: all 0.3s ease; }
    .chart-container { height: 350px; }
    footer { background: var(--primary-dark); color: #fff; text-align: center; padding: 1.5em; margin-top: 3em; }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; width: 100%; height: 4px;
    }
    .stat-card:nth-child(1)::before { background: var(--primary); }
    .stat-card:nth-child(2)::before { background: var(--success); }
    .stat-card:nth-child(3)::before { background: var(--danger); }
    .stat-card:nth-child(4)::before { background: var(--warning); }
  </style>
</head>
<body>

  <%- include('../partials/adminNavbar', { activePage: 'dashboard' }) %>
  <%- include('../partials/adminSidebar', { activePage: 'dashboard' }) %>

  <!-- Main Content -->
  <main class="container-fluid px-4 py-4">

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
      <div class="col-12 col-md-6 col-lg-3">
        <div class="card stat-card p-4">
          <h6 class="text-muted">Total Users</h6>
          <h2 class="fw-bold text-primary"><%= stats.totalUsers || 0 %></h2>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-3">
        <div class="card stat-card p-4">
          <h6 class="text-muted">Active Subscriptions</h6>
          <h2 class="fw-bold text-success"><%= stats.activeSubscriptions || 0 %></h2>
        </div>
      </div>
      <div class="col-12 col-md-6 col-lg-3">
        <div class="card stat-card p-4">
          <h6 class="text-muted">Pending Complaints</h6>
          <h2 class="fw-bold text-danger"><%= stats.totalComplaints || 0 %></h2>
        </div>
      </div>
      <!-- <div class="col-12 col-md-6 col-lg-3">
        <div class="card stat-card p-4">
          <h6 class="text-muted">Total Spent</h6>
          <h2 class="fw-bold text-dark">R <%= stats.totalSpent || 0 %></h2>
        </div>
      </div> -->
    </div>

    <!-- Spending Charts -->
    <div class="row g-4 mb-5">
      <div class="col-12 col-lg-4">
        <div class="card p-3">
          <h6 class="text-primary text-center fw-bold"><i class="fas fa-chart-pie me-2"></i>Spending by Category</h6>
          <div class="chart-container"><canvas id="categoryChart"></canvas></div>
        </div>
      </div>
      <div class="col-12 col-lg-4">
        <div class="card p-3">
          <h6 class="text-primary text-center fw-bold"><i class="fas fa-store me-2"></i>Spending by Shop</h6>
          <div class="chart-container"><canvas id="shopChart"></canvas></div>
        </div>
      </div>
      <div class="col-12 col-lg-4">
        <div class="card p-3">
          <h6 class="text-primary text-center fw-bold"><i class="fas fa-map-marker-alt me-2"></i>Spending by Province</h6>
          <div class="chart-container"><canvas id="addressChart"></canvas></div>
        </div>
      </div>
    </div>

    <!-- Subscription Insights -->
    <div class="row g-4 mt-4">
      <!-- Usage Chart -->
      <div class="col-12 col-lg-6">
        <div class="card p-3">
          <h6 class="text-primary fw-bold text-center"><i class="fas fa-chart-pie me-2"></i> Subscription Plan Usage</h6>
          <div class="chart-container"><canvas id="planUsageChart"></canvas></div>
          <p class="mt-3 text-center text-muted">
            🏆 Most Used Plan: <strong class="text-primary"><%= mostUsedPlan.plan_name %></strong>
            (<%= mostUsedPlan.total_users %> users)
          </p>
        </div>
      </div>
      <!-- Revenue Chart -->
      <div class="col-12 col-lg-6">
        <div class="card p-3">
          <h6 class="text-success fw-bold text-center"><i class="fas fa-coins me-2"></i> Revenue per Plan</h6>
          <div class="chart-container"><canvas id="planRevenueChart"></canvas></div>
          <p class="mt-3 text-center text-muted">💰 Total revenue generated by each active plan.</p>
        </div>
      </div>
    </div>

  </main>

  <footer class="mt-5">
    <p>&copy; <%= new Date().getFullYear() %> FinTrack | Built with ❤️ by Desmond</p>
  </footer>

  <!-- Scripts -->
  <script>
    const categoryData = <%- JSON.stringify(spendingByCategory || []) %>;
    const shopData = <%- JSON.stringify(spendingByShop || []) %>;
    const addressData = <%- JSON.stringify(spendingByAddress || []) %>;
    const planUsageData = <%- planUsageData %>;
    const planRevenueData = <%- planRevenueData %>;

    // Helper - format currency
    const formatR = (val) => 'R' + parseFloat(val || 0).toLocaleString();

    // Category Chart
    if (categoryData.length) {
      new Chart(document.getElementById('categoryChart'), {
        type: 'doughnut',
        data: {
          labels: categoryData.map(d => d.category || 'Unknown'),
          datasets: [{
            data: categoryData.map(d => d.total),
            backgroundColor: ['#007bff','#28a745','#ffc107','#dc3545','#20c997','#6f42c1','#0dcaf0','#fd7e14','#6610f2','#17a2b8'],
            borderWidth: 2, borderColor: '#fff'
          }]
        },
        options: {
          plugins: { legend: { position: 'bottom' } },
          cutout: '65%'
        }
      });
    }

    // Shop Chart
    if (shopData.length) {
      new Chart(document.getElementById('shopChart'), {
        type: 'bar',
        data: {
          labels: shopData.map(d => d.shop),
          datasets: [{
            label: 'Total Spent (R)',
            data: shopData.map(d => d.total),
            backgroundColor: '#004080',
            borderRadius: 8
          }]
        },
        options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
      });
    }

    // Address Chart
    if (addressData.length) {
      new Chart(document.getElementById('addressChart'), {
        type: 'pie',
        data: {
          labels: addressData.map(d => d.province),
          datasets: [{
            data: addressData.map(d => d.total_spent),
            backgroundColor: ['#6610f2','#20c997','#fd7e14','#e83e8c','#ffc107','#007bff','#28a745','#dc3545'],
            borderWidth: 2, borderColor: '#fff'
          }]
        },
        options: { plugins: { legend: { position: 'bottom' } } }
      });
    }

    // Plan Usage Chart
    if (planUsageData && planUsageData.length > 0) {
      const ctx = document.getElementById("planUsageChart").getContext("2d");
      const labels = planUsageData.map(p => p.plan_name);
      const data = planUsageData.map(p => p.total_users);
      const total = data.reduce((a, b) => a + b, 0);

      new Chart(ctx, {
        type: "doughnut",
        data: {
          labels,
          datasets: [{
            data,
            backgroundColor: ["#004080","#007bff","#28a745","#ffc107","#dc3545","#6f42c1","#20c997","#0dcaf0"],
            borderColor: "#fff", borderWidth: 3, hoverOffset: 10
          }]
        },
        options: {
          responsive: true, cutout: "65%",
          plugins: {
            legend: { position: "bottom" },
            tooltip: {
              callbacks: {
                label: c => `${c.label}: ${c.raw} users (${((c.raw / total) * 100).toFixed(1)}%)`
              }
            },
            datalabels: {
              color: "#fff",
              font: { weight: "bold", size: 13 },
              formatter: (v) => `${((v / total) * 100).toFixed(1)}%`
            }
          }
        },
        plugins: [ChartDataLabels]
      });
    }

    // Plan Revenue Chart
    if (planRevenueData && planRevenueData.length > 0) {
      const ctx2 = document.getElementById("planRevenueChart").getContext("2d");
      const labels = planRevenueData.map(p => p.plan_name);
      const data = planRevenueData.map(p => parseFloat(p.total_revenue) || 0);

      new Chart(ctx2, {
        type: "bar",
        data: {
          labels,
          datasets: [{
            label: "Revenue (R)",
            data,
            backgroundColor: "#28a745",
            borderRadius: 8,
            borderSkipped: false
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              beginAtZero: true,
              ticks: { callback: (value) => "R" + value.toLocaleString() },
              grid: { color: "#e9ecef" }
            },
            x: { grid: { display: false } }
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: { label: (ctx) => "R" + ctx.raw.toLocaleString() }
            }
          }
        }
      });
    }
  </script>
</body>
</html>
