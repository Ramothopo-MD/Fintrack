<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Error - FinTrack</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
    <style>
      body {
        background: #f8f9fa;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      }
      .error-card {
        max-width: 520px;
        margin: auto;
        padding: 2.5rem;
        border-radius: 1.2rem;
        background-color: #fff;
        box-shadow: 0 6px 25px rgba(0, 0, 0, 0.08);
      }
      .error-icon {
        font-size: 4rem;
        color: #dc3545;
        line-height: 1;
      }
      .btn-custom {
        min-width: 140px;
        font-weight: 500;
      }
      .countdown {
        font-weight: 600;
        color: #0d6efd;
      }
    </style>
  </head>
  <body class="d-flex align-items-center justify-content-center vh-100">
    <div class="error-card text-center animate__animated animate__fadeInUp">
      <!-- Icon -->
      <div class="error-icon mb-3 animate__animated animate__pulse animate__infinite">
        <i class="bi bi-exclamation-circle-fill"></i>
      </div>

      <!-- Headline -->
      <h3 class="fw-bold text-danger">Oops! Something went wrong.</h3>

      <!-- Message -->
      <p class="text-muted mt-2">
        <%= message || "We couldn’t process your request. Please try again later." %>
      </p>

      <!-- Redirect Message -->
      <% if (user && user.role === 'admin') { %>
        <p>You’ll be redirected to the <strong>Admin Dashboard</strong> in
          <span class="countdown" id="countdown">3</span> seconds.</p>
      <% } else if (user && user.role === 'user') { %>
        <p>You’ll be redirected to your <strong>User Dashboard</strong> in
          <span class="countdown" id="countdown">3</span> seconds.</p>
      <% } else { %>
        <p>You’ll be redirected to the <strong>Home Page</strong> in
          <span class="countdown" id="countdown">3</span> seconds.</p>
      <% } %>

      <!-- Buttons -->
      <div class="mt-4 d-grid gap-2 d-sm-flex justify-content-sm-center">
        <a href="/" class="btn btn-danger btn-custom">
          <i class="bi bi-house-door-fill me-1"></i> Home
        </a>

        <% if (user && user.role === 'admin') { %>
          <a href="/admin/dashboard" class="btn btn-outline-secondary btn-custom">
            <i class="bi bi-speedometer2 me-1"></i> Admin Dashboard
          </a>
        <% } else if (user && user.role === 'user') { %>
          <a href="/user/dashboard" class="btn btn-outline-secondary btn-custom">
            <i class="bi bi-person-circle me-1"></i> User Dashboard
          </a>
        <% } else { %>
          <a href="/login" class="btn btn-outline-secondary btn-custom">
            <i class="bi bi-box-arrow-in-right me-1"></i> Login
          </a>
        <% } %>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      let timeLeft = 3;
      const countdownEl = document.getElementById("countdown");

      const timer = setInterval(() => {
        timeLeft--;
        countdownEl.textContent = timeLeft;

        if (timeLeft <= 0) {
          clearInterval(timer);
          <% if (user && user.role === 'admin') { %>
            window.location.href = "/admin/dashboard";
          <% } else if (user && user.role === 'user') { %>
            window.location.href = "/user/dashboard";
          <% } else { %>
            window.location.href = "/";
          <% } %>
        }
      }, 1000);
    </script>
  </body>
</html>
