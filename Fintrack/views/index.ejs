<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FinTrack — Smart Receipt Management</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --primary: #2563eb;
      --primary-dark: #1d4ed8;
      --secondary: #002855;
      --light: #f8fafc;
      --accent: #10b981;
      --text: #334155;
    }

    body { font-family: 'Inter', sans-serif; color: var(--text); line-height: 1.6; overflow-x: hidden; }

    /* 🌟 NAVBAR */
    .navbar-custom {
      background: transparent;
      transition: all 0.4s ease;
      padding: 1.2rem 0;
    }
    .navbar-custom.scrolled {
      background: rgba(0, 40, 85, 0.95);
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
      backdrop-filter: blur(10px);
      padding: 0.6rem 0;
    }
    .navbar-custom .nav-link {
      color: #e2e8f0;
      margin: 0 0.7rem;
      font-weight: 500;
    }
    .navbar-custom .nav-link:hover,
    .navbar-custom .nav-link.active { color: #fff; }
    .navbar-brand { font-weight: 700; color: #fff !important; }

    /* HERO SECTION */
    .hero {
      position: relative;
      height: 100vh;
      color: white;
      background: url('/images/fintrackcover.jpeg') center/cover no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .hero::before {
      content: "";
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: linear-gradient(to bottom right, rgba(0,40,85,0.7), rgba(37,99,235,0.5));
      z-index: 1;
    }
    .hero .container { z-index: 2; }
    .hero h1 { font-weight: 800; font-size: 3.5rem; line-height: 1.2; }
    .hero p { font-size: 1.25rem; opacity: 0.95; max-width: 650px; margin: 1rem auto 2rem; }

    /* BUTTONS */
    .btn-primary {
      background: var(--primary);
      border: none;
      border-radius: 50px;
      font-weight: 600;
      padding: 0.75rem 2rem;
      transition: 0.3s;
    }
    .btn-primary:hover { background: var(--primary-dark); transform: translateY(-3px); }

    /* FEATURES */
    section { padding: 100px 0; }
    .feature-icon {
      font-size: 3rem; color: var(--primary);
      width: 80px; height: 80px; line-height: 80px;
      background: rgba(37,99,235,0.1);
      border-radius: 50%; margin-bottom: 1rem;
    }
    .card { border: none; border-radius: 16px; transition: all 0.3s ease; }
    .card:hover { transform: translateY(-10px); box-shadow: 0 12px 25px rgba(0,0,0,0.1); }

    /* 🌍 DYNAMIC PRICING */
    .pricing-card {
      border: 2px solid transparent;
      border-radius: 14px;
      transition: all 0.3s ease;
      padding: 2rem;
      position: relative;
      overflow: hidden;
    }
    .pricing-card.active {
      border-color: var(--primary);
      box-shadow: 0 10px 35px rgba(37,99,235,0.2);
      transform: scale(1.05);
    }
    .pricing-card.active::before {
      content: "⭐ Recommended";
      position: absolute;
      top: 15px; right: -30px;
      background: var(--primary);
      color: white;
      transform: rotate(45deg);
      padding: 5px 30px;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .badge-plan {
      background: var(--primary);
      color: #fff;
      border-radius: 20px;
      padding: 6px 12px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .feature-list { text-align: left; }
    .feature-list li { margin-bottom: 6px; }

  footer {
  background: var(--secondary);
  color: #fff;
  padding: 60px 0 30px;
}

.footer-link {
  color: #dbeafe;
  text-decoration: none;
  transition: color 0.3s ease;
}

.footer-link:hover {
  color: #fff;
  text-decoration: underline;
}

  </style>
</head>

<body>
<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark navbar-custom fixed-top">
  <div class="container">
    <a class="navbar-brand d-flex align-items-center" href="#">
      <i class="fas fa-receipt me-2"></i> FinTrack
    </a>
    <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link active" href="#features">Features</a></li>
        <li class="nav-item"><a class="nav-link" href="#how">How It Works</a></li>
        <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
        <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
        <li class="nav-item"><a href="/user/login" class="btn btn-light btn-sm ms-2">Login</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="container">
    <h1>Smart Receipt Tracking Made Simple</h1>
    <p>Upload, organize, and analyze your receipts with AI-powered insights — join <span class="fw-bold text-warning"><%= total_users %></span>+ users today.</p>
    <a href="/user/register" class="btn btn-primary btn-lg">Get Started Free</a>
  </div>
</section>

<!-- Features -->
<section id="features" class="text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">Why Choose FinTrack?</h2>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card p-4 h-100">
          <div class="feature-icon mx-auto"><i class="fas fa-camera"></i></div>
          <h5 class="fw-bold mt-3">Smart OCR</h5>
          <p>Capture receipts instantly using AI-based OCR that extracts text, totals, and categories automatically.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-4 h-100">
          <div class="feature-icon mx-auto"><i class="fas fa-chart-line"></i></div>
          <h5 class="fw-bold mt-3">AI Analytics</h5>
          <p>Understand spending trends and track budgets with interactive charts and predictive AI insights.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-4 h-100">
          <div class="feature-icon mx-auto"><i class="fas fa-bell"></i></div>
          <h5 class="fw-bold mt-3">Budget Alerts</h5>
          <p>Stay within your goals with instant alerts when you overspend or reach category limits.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how" class="bg-light text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">How It Works</h2>
    <div class="row g-4">
      <div class="col-md-4"><div class="card p-4 h-100"><h5>1. Upload</h5><p>Snap or upload your receipts easily via mobile or desktop.</p></div></div>
      <div class="col-md-4"><div class="card p-4 h-100"><h5>2. Process</h5><p>Our AI parses every item and category automatically in seconds.</p></div></div>
      <div class="col-md-4"><div class="card p-4 h-100"><h5>3. Analyze</h5><p>Get spending summaries, insights, and personalized financial reports.</p></div></div>
    </div>
  </div>
</section>

<!-- 💳 Dynamic Pricing -->
<section id="pricing" class="text-center">
  <div class="container">
    <h2 class="fw-bold mb-5">Pricing Plans</h2>
    <div class="row g-4 justify-content-center">
      <% if (plans && plans.length > 0) { %>
        <% plans.forEach(plan => { %>
          <div class="col-md-4">
            <div class="pricing-card h-100 <%= plan.type === 'organization' ? 'active' : '' %>">
              <h4 class="fw-bold text-primary mb-2"><%= plan.name %></h4>
              <p class="fs-3 fw-bold text-dark">R<%= plan.price %><span class="fs-6 text-muted"> / month</span></p>
              <p class="text-muted mb-3"><%= plan.description || 'No description provided.' %></p>
              <span class="badge-plan mb-3"><i class="fas fa-user"></i> <%= plan.type.charAt(0).toUpperCase() + plan.type.slice(1) %></span>

              <ul class="feature-list list-unstyled mt-3 mb-4 px-3">
                <li><i class="fas fa-check text-success me-2"></i> Request Limit: <%= plan.request_limit %>/month</li>
                <li><i class="fas fa-check text-success me-2"></i> Trial Days: <%= plan.trial_days %></li>
                <li><i class="fas fa-check text-success me-2"></i> Billing: <%= plan.billing_cycle === 'yearly' ? 'Yearly' : 'Monthly' %></li>
                <li><i class="fas fa-check text-success me-2"></i> Status: <%= plan.status %></li>
              </ul>

              <% if (plan.features) { %>
                <div class="mb-3">
                  <% plan.features.split(',').slice(0,4).forEach(f => { %>
                    <div><i class="fas fa-circle-check text-success me-2"></i><%= f.trim() %></div>
                  <% }) %>
                </div>
              <% } %>

              <a href="/user/register" class="btn btn-primary w-100">Choose Plan</a>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No active plans available yet.</p>
      <% } %>
    </div>
  </div>
</section>



<footer class="text-center">
  <div class="container">
    <div class="row justify-content-center mb-4">
      <!-- Brand & Info -->
      <div class="col-md-4 mb-3">
        <h5 class="fw-bold text-white mb-3">
          <i class="fas fa-receipt me-2 text-primary"></i> FinTrack
        </h5>
        <p class="small text-light">
          Smart receipt management powered by AI.  
          Simplify expense tracking and budgeting with ease.
        </p>
      </div>

      <!-- Contact Details -->
      <div class="col-md-4 mb-3 text-start text-md-center">
        <h6 class="fw-bold text-white mb-3">Contact Us</h6>
        <p class="mb-1 text-light"><i class="fas fa-envelope me-2 text-primary"></i> support@fintrack.co.za</p>
        <p class="mb-1 text-light"><i class="fas fa-phone me-2 text-primary"></i> +27 65 123 4567</p>
        <p class="mb-0 text-light"><i class="fas fa-map-marker-alt me-2 text-primary"></i> Polokwane, South Africa</p>
      </div>

      <!-- Quick Links -->
      <div class="col-md-4 mb-3 text-start text-md-end">
        <h6 class="fw-bold text-white mb-3">Quick Links</h6>
        <p class="mb-1"><a href="#features" class="footer-link">Features</a></p>
        <p class="mb-1"><a href="#pricing" class="footer-link">Pricing</a></p>
        <p class="mb-1"><a href="/user/login" class="footer-link">Login</a></p>
        <p class="mb-0"><a href="/user/register" class="footer-link">Sign Up</a></p>
      </div>
    </div>

    <hr class="border-light my-3" style="opacity:0.15;">
    <p class="mb-2 small text-light">© 2025 FinTrack. All rights reserved.</p>
    <p class="small">
      <a href="#" class="footer-link me-3">Privacy Policy</a>
      <a href="#" class="footer-link">Terms of Service</a>
    </p>
  </div>
</footer>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  window.addEventListener('scroll', () => {
    const nav = document.querySelector('.navbar-custom');
    nav.classList.toggle('scrolled', window.scrollY > 60);
  });
</script>
</body>
</html>
