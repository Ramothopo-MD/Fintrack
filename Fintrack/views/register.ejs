<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Create Account - FinTrack</title>

  <!-- ✅ Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --primary: #004080;
      --light-bg: #f5f9ff;
      --success: #198754;
      --danger: #dc3545;
    }

    body {
      background-color: var(--light-bg);
      font-family: 'Segoe UI', sans-serif;
    }

    .form-container {
      max-width: 550px;
      margin: 60px auto;
    }

    .card {
      border: none;
      border-radius: 14px;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }

    .card-header {
      background: var(--primary);
      color: #fff;
      border-radius: 14px 14px 0 0;
    }

    label {
      font-weight: 500;
    }

    #passwordHelp span {
      display: block;
      font-size: 0.85rem;
      color: #6c757d;
      transition: 0.3s ease;
    }

    #passwordHelp span.valid {
      color: var(--success);
      text-decoration: line-through;
    }

    #matchMessage {
      font-size: 0.85rem;
      margin-top: 5px;
      color: var(--danger);
    }

    .btn-primary {
      background-color: var(--primary);
      border: none;
      transition: 0.3s ease;
    }

    .btn-primary:hover {
      background-color: #003366;
    }
  </style>
</head>
<body>

<div class="container form-container">
  <div class="card">
    <div class="card-header text-center py-3">
      <h4 class="mb-0">Create Your FinTrack Account</h4>
    </div>

    <div class="card-body p-4">
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger text-center"><%= error %></div>
      <% } %>

      <form action="/user/register" method="POST" id="registerForm">
        <!-- Name Fields -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label>First Name</label>
            <input type="text" name="name" class="form-control" placeholder="John" required>
          </div>
          <div class="col-md-6 mb-3">
            <label>Surname</label>
            <input type="text" name="surname" class="form-control" placeholder="Doe" required>
          </div>
        </div>

        <!-- Email -->
        <div class="mb-3">
          <label>Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="example@email.com" required>
        </div>

        <!-- Password Fields -->
        <div class="row">
          <div class="col-md-6 mb-3">
            <label>Password</label>
            <input type="password" name="password" id="password" class="form-control" placeholder="••••••••" required>
            <div id="passwordHelp" class="form-text mt-2">
              <span id="length">• Minimum 8 characters</span>
              <span id="uppercase">• One uppercase letter (A–Z)</span>
              <span id="lowercase">• One lowercase letter (a–z)</span>
              <span id="number">• One number (0–9)</span>
              <span id="special">• One special character (!@#$%^&*)</span>
            </div>
          </div>

          <div class="col-md-6 mb-3">
            <label>Confirm Password</label>
            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="••••••••" required>
            <div id="matchMessage"></div>
          </div>
        </div>

        <!-- Location Fields -->
        <div class="row">
          <div class="col-md-4 mb-3">
            <label>Country</label>
            <input type="text" name="country" class="form-control" placeholder="South Africa" required>
          </div>

          <div class="col-md-4 mb-3">
            <label>Province</label>
            <select name="province" class="form-control" required>
              <option value="" disabled selected>Select province</option>
              <option value="Gauteng">Gauteng</option>
              <option value="Western Cape">Western Cape</option>
              <option value="KwaZulu-Natal">KwaZulu-Natal</option>
              <option value="Eastern Cape">Eastern Cape</option>
              <option value="Free State">Free State</option>
              <option value="Limpopo">Limpopo</option>
              <option value="Mpumalanga">Mpumalanga</option>
              <option value="North West">North West</option>
              <option value="Northern Cape">Northern Cape</option>
            </select>
          </div>

          <div class="col-md-4 mb-3">
            <label>City</label>
            <input type="text" name="city" class="form-control" placeholder="Polokwane" required>
          </div>
        </div>

        <!-- Hidden Role -->
        <input type="hidden" name="role" value="USER">

        <!-- Submit -->
        <div class="d-grid mt-3">
          <button type="submit" id="submitBtn" class="btn btn-primary" disabled>
            Create Account
          </button>
        </div>
      </form>
    </div>

    <div class="card-footer text-center py-3">
      <small>Already have an account? <a href="/login" class="text-decoration-none text-primary">Login here</a></small>
    </div>
  </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- ✅ Clean Password Validation -->
<script>
  const password = document.getElementById('password');
  const confirmPassword = document.getElementById('confirmPassword');
  const submitBtn = document.getElementById('submitBtn');
  const matchMsg = document.getElementById('matchMessage');

  const rules = {
    length: document.getElementById('length'),
    uppercase: document.getElementById('uppercase'),
    lowercase: document.getElementById('lowercase'),
    number: document.getElementById('number'),
    special: document.getElementById('special'),
  };

  function validatePassword() {
    const value = password.value;
    let valid = true;

    // ✅ Check all rules
    const checks = {
      length: value.length >= 8,
      uppercase: /[A-Z]/.test(value),
      lowercase: /[a-z]/.test(value),
      number: /[0-9]/.test(value),
      special: /[!@#$%^&*(),.?":{}|<>]/.test(value)
    };

    Object.keys(checks).forEach(rule => {
      rules[rule].classList.toggle('valid', checks[rule]);
      if (!checks[rule]) valid = false;
    });

    // ✅ Confirm password match
    if (confirmPassword.value && confirmPassword.value !== value) {
      matchMsg.textContent = "Passwords do not match";
      valid = false;
    } else {
      matchMsg.textContent = "";
    }

    // ✅ Enable or disable button
    submitBtn.disabled = !valid;
  }

  password.addEventListener('input', validatePassword);
  confirmPassword.addEventListener('input', validatePassword);
</script>

</body>
</html>
