<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title: 'Choose Subscription Plan - FinTrack' }) %>
<body class="bg-light">

  <!-- Navbar + Sidebar -->
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <!-- Header -->
  <section class="text-center py-5 bg-primary text-white shadow-sm">
    <div class="container">
      <h2 class="fw-bold display-6">Choose Your Subscription Plan</h2>
      <p class="lead mb-0 opacity-75">Pick a plan that fits your growth — upgrade anytime.</p>
    </div>
  </section>

  <!-- Plans -->
  <main class="container my-5">
    <div class="row g-4 justify-content-center">
      <% if (plans && plans.length > 0) { %>
        <% plans.forEach((plan, idx) => { %>
          <div class="col-md-4 col-sm-6">
            <div class="card h-100 border-0 plan-card shadow-sm position-relative overflow-hidden
              <%= idx === 1 ? 'featured-plan' : '' %>">
              
              <% if (idx === 1) { %>
                <div class="ribbon text-white fw-bold small">Most Popular</div>
              <% } %>

              <div class="card-body text-center p-4">
                <h5 class="fw-bold text-dark"><%= plan.name %></h5>
                <p class="text-muted mb-2"><%= plan.type.charAt(0).toUpperCase() + plan.type.slice(1) %> Plan</p>

                <h3 class="text-primary fw-bold mb-3">
                  R<%= Number(plan.price).toFixed(2) %>
                  <small class="text-muted fs-6"> / <%= plan.billing_cycle %></small>
                </h3>

                <p class="small text-muted mb-3"><%= plan.description || 'No description provided.' %></p>

                <!-- Features -->
                <ul class="list-group list-group-flush text-start mb-3">
                  <% 
                    let featuresList = [];
                    try { featuresList = plan.features ? JSON.parse(plan.features) : []; }
                    catch(e) { featuresList = []; }
                  %>
                  <% if (featuresList.length) { %>
                    <% featuresList.forEach(f => { %>
                      <li class="list-group-item border-0 ps-0">
                        <i class="bi bi-check-circle text-success me-2"></i> <%= f %>
                      </li>
                    <% }) %>
                  <% } %>
                  <li class="list-group-item border-0 ps-0">
                    <i class="bi bi-hdd-network text-primary me-2"></i>
                    <strong><%= plan.request_limit %></strong> requests/month
                  </li>
                  <% if (plan.trial_days > 0) { %>
                    <li class="list-group-item border-0 ps-0 text-success">
                      <i class="bi bi-gift"></i> <%= plan.trial_days %>-day free trial
                    </li>
                  <% } %>
                </ul>

                <button
                  type="button"
                  class="btn btn-success w-100 fw-semibold shadow-sm"
                  data-bs-toggle="modal"
                  data-bs-target="#confirmModal"
                  data-plan-id="<%= plan.plan_id %>"
                  data-plan-name="<%= plan.name %>"
                  data-plan-price="R<%= Number(plan.price).toFixed(2) %>"
                  data-plan-cycle="<%= plan.billing_cycle %>"
                  data-plan-description="<%= plan.description || 'No description provided.' %>">
                  <i class="bi bi-lock-fill me-1"></i> Pay with Paystack
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="text-center py-5">
          <p class="text-muted fs-5">🚫 No subscription plans available right now.</p>
          <a href="/user/dashboard" class="btn btn-outline-primary mt-3">Back to Dashboard</a>
        </div>
      <% } %>
    </div>
  </main>


  <!-- ✅ Modal -->
  <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="modal-header text-white" style="background:linear-gradient(90deg,#007bff,#00b4d8);">
          <h5 class="modal-title fw-bold">
            <i class="bi bi-credit-card me-2"></i> Confirm Subscription
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body bg-light">
          <div class="text-center mb-4">
            <h4 id="modalPlanName" class="fw-bold mb-1"></h4>
            <p id="modalPlanDesc" class="small text-muted mb-3"></p>
            <div class="d-inline-block bg-white border rounded px-4 py-3 shadow-sm">
              <p class="mb-1"><strong>Billing:</strong>
                <span id="modalPlanCycle" class="text-primary fw-semibold"></span>
              </p>
              <p class="mb-0 fs-5 fw-bold text-success" id="modalPlanPrice"></p>
            </div>
          </div>

          <hr>

          <!-- 💳 Trust / Security badges -->
          <div class="text-center my-3">
            <img src="https://trustlock.co/wp-content/uploads/2019/01/guaranteed-safe-checkout-22.png"
                 alt="Guaranteed Safe Checkout" width="260" class="img-fluid mb-2">
            <p class="small text-muted mb-0">
              <i class="fas fa-lock text-success me-1"></i> 256-bit SSL Encryption • PCI-DSS Compliant • 3-D Secure
            </p>
          </div>

          <!-- Spinner -->
          <div id="loadingSpinner" class="d-none text-center my-4">
            <div class="spinner-border text-primary" style="width:3rem;height:3rem;"></div>
            <p class="mt-3 fw-semibold text-muted">Redirecting to Paystack... please wait</p>
          </div>
        </div>

        <div class="modal-footer bg-white">
          <form id="confirmForm" action="/subscriptions/subscribe" method="POST"
                class="w-100 d-flex justify-content-between align-items-center">
            <input type="hidden" name="planId" id="modalPlanId">
            <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
              <i class="bi bi-x-circle me-1"></i> Cancel
            </button>
            <button type="submit" id="confirmPayBtn" class="btn btn-success px-4 fw-semibold shadow-sm">
              <i class="bi bi-lock-fill me-1"></i> Confirm & Pay
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Populate modal
    const confirmModal = document.getElementById('confirmModal');
    confirmModal?.addEventListener('show.bs.modal', e => {
      const b = e.relatedTarget;
      modalPlanId.value = b.dataset.planId;
      modalPlanName.textContent = b.dataset.planName;
      modalPlanPrice.textContent = b.dataset.planPrice;
      modalPlanCycle.textContent = b.dataset.planCycle;
      modalPlanDesc.textContent = b.dataset.planDescription;
    });

    // Spinner on submit
    confirmForm?.addEventListener('submit', () => {
      confirmPayBtn.disabled = true;
      confirmPayBtn.innerText = 'Processing...';
      loadingSpinner.classList.remove('d-none');
    });
  </script>

  <style>
    .plan-card { transition: all .3s ease; border-radius: 15px; }
    .plan-card:hover { transform: translateY(-8px); box-shadow:0 12px 25px rgba(0,0,0,.1); }
    .featured-plan { border:2px solid #007bff; }
    .ribbon {
      position:absolute; top:15px; right:-40px;
      background:#007bff; transform:rotate(45deg);
      width:160px; text-align:center; padding:4px 0;
      font-size:.8rem; box-shadow:0 3px 6px rgba(0,0,0,.2);
    }
  </style>
</body>
</html>
