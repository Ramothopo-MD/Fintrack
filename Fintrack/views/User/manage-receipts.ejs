<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title: 'Manage Receipts - FinTrack' }) %>

  <body class="bg-light">
    <!-- ✅ Navbar + Sidebar -->
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <!-- ✅ Page Header -->
    <header class="bg-primary text-white py-4 shadow-sm mb-4">
      <div class="container">
        <h2 class="fw-bold mb-1">
          <i class="bi bi-receipt-cutoff me-2"></i> Manage Receipts
        </h2>
        <p class="mb-0 text-white-50">
          Upload, edit, and review all your spending receipts in one place.
        </p>
      </div>
    </header>

    <!-- ✅ Stats Overview -->
    <section class="container mb-5">
      <div class="row g-4 text-center">
        <div class="col-md-3 col-sm-6">
          <div class="card shadow-sm border-0 rounded-4 p-3 h-100">
            <h6 class="text-muted mb-1">Total Receipts</h6>
            <h2 class="fw-bold text-primary"><%= stats.totalReceipts %></h2>
          </div>
        </div>

        <div class="col-md-3 col-sm-6">
          <div class="card shadow-sm border-0 rounded-4 p-3 h-100">
            <h6 class="text-muted mb-1">Total Spent</h6>
            <h2 class="fw-bold text-success">R<%= stats.totalSpent.toFixed(2) %></h2>
          </div>
        </div>

        <div class="col-md-3 col-sm-6">
          <div class="card shadow-sm border-0 rounded-4 p-3 h-100">
            <h6 class="text-muted mb-1">Average / Receipt</h6>
            <h2 class="fw-bold text-info">R<%= stats.avgSpent %></h2>
          </div>
        </div>

        <div class="col-md-3 col-sm-6">
          <div class="card shadow-sm border-0 rounded-4 p-3 h-100">
            <h6 class="text-muted mb-1">Top Category</h6>
            <h2 class="fw-bold text-danger"><%= stats.topCategory %></h2>
          </div>
        </div>
      </div>
    </section>

    <!-- ✅ Charts Section -->
    <section class="container mb-5">
      <div class="row g-4">
        <div class="col-lg-6">
          <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="fw-semibold text-center mb-3">
              <i class="bi bi-pie-chart me-2 text-primary"></i> Spending by Category
            </h6>
            <canvas id="categoryChart" height="180"></canvas>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="card shadow-sm border-0 rounded-4 p-3">
            <h6 class="fw-semibold text-center mb-3">
              <i class="bi bi-bar-chart-line me-2 text-primary"></i> Monthly Spending Trend
            </h6>
            <canvas id="monthlyChart" height="180"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- ✅ Main Table Section -->
    <main class="container-fluid px-4 pb-5">
      <% if (success) { %>
        <div class="alert alert-success shadow-sm text-center fw-semibold">
          ✅ <%= success %>
        </div>
      <% } else if (error) { %>
        <div class="alert alert-danger shadow-sm text-center fw-semibold">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <div class="d-flex justify-content-end mb-4">
        <button
          class="btn btn-info fw-semibold shadow-sm rounded-pill px-4"
          data-bs-toggle="modal"
          data-bs-target="#autoReceiptModal"
        >
          <i class="bi bi-robot me-2"></i> Add Automatically
        </button>
      </div>

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-primary text-white fw-semibold rounded-top-4">
          <i class="bi bi-card-list me-2"></i> Your Receipts
        </div>

        <div class="card-body p-0">
          <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Store</th>
                <th>Date</th>
                <th>Total (R)</th>
                <th>Payment</th>
                <th>Items</th>
                <th class="text-center">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (receipts && receipts.length > 0) { %>
                <% receipts.forEach(receipt => { %>
                  <tr>
                    <td class="fw-semibold"><%= receipt.store_name %></td>
                    <td><%= receipt.date ? new Date(receipt.date).toISOString().split('T')[0] : '' %></td>
                    <td class="fw-semibold text-success">
                      R <%= Number(receipt.total || 0).toLocaleString('en-ZA', { minimumFractionDigits: 2 }) %>
                    </td>
                    <td><%= receipt.payment_method %></td>
                    <td>
                      <ul class="list-unstyled small mb-0">
                        <% (receipt.items || []).forEach(item => { %>
                          <li>
                            <%= item.name %> –
                            <span class="text-muted">
                              R<%= Number(item.price || 0).toFixed(2) %>
                            </span>
                            <% if (item.quantity) { %> (x<%= item.quantity %>) <% } %>
                          </li>
                        <% }) %>
                      </ul>
                    </td>
                    <td class="text-center">
                      <div class="btn-group">
                        <button
                          class="btn btn-sm btn-outline-primary"
                          data-bs-toggle="modal"
                          data-bs-target="#editReceiptModal-<%= receipt.receipt_id %>"
                        >
                          <i class="bi bi-pencil-square me-1"></i> Edit
                        </button>
                        <form
                          action="/api/receipts/<%= receipt.receipt_id %>?_method=DELETE"
                          method="POST"
                          style="display:inline;"
                        >
                          <button
                            class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Delete this receipt?')"
                          >
                            <i class="bi bi-trash me-1"></i> Delete
                          </button>
                        </form>
                        <button
                          class="btn btn-sm btn-outline-info"
                          data-bs-toggle="modal"
                          data-bs-target="#itemsModal-<%= receipt.receipt_id %>"
                        >
                          <i class="bi bi-list-ul me-1"></i> View Items
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="text-center py-5 text-muted">
                    <i class="bi bi-folder-x me-1"></i> No receipts found.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>

    <!-- ✅ Auto Receipt Modal -->
    <div class="modal fade" id="autoReceiptModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content rounded-4 border-0 shadow">
          <div class="modal-header bg-info text-white">
            <h5 class="modal-title fw-semibold">
              <i class="bi bi-robot me-2"></i> Add Receipt Automatically
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div id="loadingSpinner" class="d-none text-center my-4">
              <div class="spinner-border text-primary" style="width:3rem; height:3rem;"></div>
              <p class="mt-2 text-muted">Extracting receipt data... please wait</p>
            </div>

            <form action="/api/parse-receipt" method="POST" enctype="multipart/form-data">
              <div class="mb-3">
                <label class="form-label fw-semibold">Choose Receipt File</label>
                <input type="file" name="image" class="form-control" accept="image/*" required>
              </div>
              <div class="text-end">
                <button type="submit" class="btn btn-info fw-semibold">
                  <i class="bi bi-cloud-upload me-1"></i> Upload & Process
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- ✅ Dynamic Modals -->
    <% if (receipts && receipts.length > 0) { %>
      <% receipts.forEach(receipt => { %>
        <!-- 📝 Edit Receipt Modal -->
        <div class="modal fade" id="editReceiptModal-<%= receipt.receipt_id %>" tabindex="-1">
          <div class="modal-dialog modal-lg">
            <div class="modal-content rounded-4 border-0 shadow">
              <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i> Edit Receipt</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <form action="/api/receipts/<%= receipt.receipt_id %>?_method=PUT" method="POST">
                  <div class="row g-3">
                    <div class="col-md-6">
                      <label class="form-label">Store Name</label>
                      <input type="text" name="store_name" class="form-control" value="<%= receipt.store_name %>" required>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Date</label>
                      <input type="date" name="date" class="form-control" value="<%= receipt.date ? new Date(receipt.date).toISOString().split('T')[0] : '' %>" required>
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Total (R)</label>
                      <input type="number" step="0.01" name="total" class="form-control" value="<%= receipt.total %>" required>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Payment Method</label>
                      <select name="payment_method" class="form-select">
                        <option value="CASH" <%= receipt.payment_method === 'CASH' ? 'selected' : '' %>>Cash</option>
                        <option value="CARD" <%= receipt.payment_method === 'CARD' ? 'selected' : '' %>>Card</option>
                        <option value="EFT" <%= receipt.payment_method === 'EFT' ? 'selected' : '' %>>EFT</option>
                        <option value="MOBILE" <%= receipt.payment_method === 'MOBILE' ? 'selected' : '' %>>Mobile</option>
                        <option value="VOUCHER" <%= receipt.payment_method === 'VOUCHER' ? 'selected' : '' %>>Voucher</option>
                        <option value="UNKNOWN" <%= receipt.payment_method === 'UNKNOWN' ? 'selected' : '' %>>Other</option>
                      </select>
                    </div>
                  </div>
                  <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary fw-semibold">
                      <i class="bi bi-save2 me-1"></i> Update Receipt
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>

        <!-- 📦 Items Modal -->
        <div class="modal fade" id="itemsModal-<%= receipt.receipt_id %>" tabindex="-1">
          <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content rounded-4 border-0 shadow-lg">
              <div class="modal-header bg-secondary text-white">
                <h5 class="modal-title fw-semibold">
                  <i class="bi bi-list-ul me-2"></i> Items for <%= receipt.store_name %>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body bg-light">
                <% if (receipt.items && receipt.items.length > 0) { %>
                  <div class="table-responsive">
                    <table class="table table-bordered align-middle bg-white rounded-3 shadow-sm">
                      <thead class="table-primary text-center">
                        <tr>
                          <th>Item</th>
                          <th>Price (R)</th>
                          <th>Qty</th>
                          <th>Category</th>
                          <th style="width: 250px;">Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% receipt.items.forEach(item => { %>
                          <tr>
                            <form action="/items/update-item/<%= item.item_id %>" method="POST">
                              <td><input type="text" name="name" class="form-control form-control-sm" value="<%= item.name %>"></td>
                              <td><input type="number" step="0.01" name="price" class="form-control form-control-sm" value="<%= item.price %>"></td>
                              <td><input type="number" name="quantity" class="form-control form-control-sm" value="<%= item.quantity || 1 %>"></td>
                              <td><input type="text" name="category" class="form-control form-control-sm" value="<%= item.category || '' %>"></td>
                              <td class="text-center text-nowrap">
                                <!-- <button type="button" class="btn btn-sm btn-info me-1" 
                                  onclick="alert('📦 Item Details:\\nName: <%= item.name %>\\nPrice: R<%= item.price %>\\nQty: <%= item.quantity || 1 %>\\nCategory: <%= item.category || 'N/A' %>')">
                                  <i class="bi bi-eye me-1"></i> View
                                </button> -->
                                <button type="submit" class="btn btn-sm btn-success me-1">
                                  <i class="bi bi-pencil-square me-1"></i> Edit
                                </button>
                                <form action="/items/delete-item/<%= item.item_id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('🗑️ Delete this item?')">
                                  <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash me-1"></i> Delete
                                  </button>
                                </form>
                              </td>
                            </form>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <div class="alert alert-secondary text-center m-0">
                    <i class="bi bi-info-circle me-2"></i> No items available for this receipt.
                  </div>
                <% } %>
              </div>

              <div class="modal-footer bg-white">
                <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">
                  <i class="bi bi-x-circle me-1"></i> Close
                </button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>

    <!-- ✅ Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const ocrForm = document.querySelector("form[action='/api/parse-receipt']");
        const spinner = document.getElementById("loadingSpinner");
        if (ocrForm && spinner) {
          ocrForm.addEventListener("submit", () => spinner.classList.remove("d-none"));
        }
      });

      // ✅ Chart.js
      const ctx1 = document.getElementById("categoryChart");
      const ctx2 = document.getElementById("monthlyChart");

      new Chart(ctx1, {
        type: "pie",
        data: {
          labels: <%- JSON.stringify(stats.categories) %>,
          datasets: [{
            label: "Spending by Category",
            data: <%- JSON.stringify(stats.categoryValues) %>,
            backgroundColor: ["#2563eb", "#16a34a", "#dc2626", "#f59e0b", "#7c3aed", "#0ea5e9"]
          }]
        },
        options: { plugins: { legend: { position: "bottom" } } }
      });

      new Chart(ctx2, {
        type: "bar",
        data: {
          labels: <%- JSON.stringify(stats.months) %>,
          datasets: [{
            label: "Monthly Spending (R)",
            data: <%- JSON.stringify(stats.monthValues) %>,
            backgroundColor: "#2563eb"
          }]
        },
        options: { scales: { y: { beginAtZero: true } } }
      });
    </script>
  </body>
</html>
