<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: 'User Dashboard - FinTrack' }) %>
<body class="bg-light">

<%- include('../partials/navbar') %>
<%- include('../partials/sidebar') %>

<!-- ===========================
     MAIN CONTENT
=========================== -->
<div class="container-fluid py-4">
  <!-- Welcome Header -->
  <div class="row mb-4">
    <div class="col-12">
<div class="d-flex gap-2">
  <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#announcementsModal">
    <i class="fas fa-bullhorn me-2"></i>Announcements
  </button>
</div>

    </div>
  </div>

  <!-- 🔔 Budget Alert -->
  <% if (stats && stats.totalSpent > stats.budget) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
      <div class="d-flex align-items-center">
        <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
        <div>
          <h5 class="alert-heading mb-1">Budget Exceeded! 🚨</h5>
          You've spent <strong>R <%= Number(stats.totalSpent).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %></strong> 
          which exceeds your budget of <strong>R <%= Number(stats.budget).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %></strong>
        </div>
      </div>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- 💰 Budget Progress Card -->
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="card-title mb-0"><i class="fas fa-chart-line text-primary me-2"></i>Budget Progress</h5>
        <span class="badge bg-primary fs-6">R <%= stats ? Number(stats.budget - stats.totalSpent).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : 0 %> left</span>
      </div>
      
      <div class="progress mb-3" style="height: 25px;">
        <div class="progress-bar bg-<%= stats && stats.budgetProgress > 90 ? 'danger' : stats.budgetProgress > 75 ? 'warning' : 'success' %> progress-bar-striped progress-bar-animated" 
             role="progressbar" 
             style="width: <%= stats ? Math.min(stats.budgetProgress, 100) : 0 %>%;"
             aria-valuenow="<%= stats ? stats.budgetProgress : 0 %>" 
             aria-valuemin="0" 
             aria-valuemax="100">
          <span class="fw-bold"><%= stats ? Math.min(stats.budgetProgress, 100) : 0 %>%</span>
        </div>
      </div>
      
      <div class="row text-center">
        <div class="col-md-4">
          <small class="text-muted">Budget</small>
          <div class="fw-bold text-success fs-5">R <%= stats ? Number(stats.budget).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></div>
        </div>
        <div class="col-md-4">
          <small class="text-muted">Spent</small>
          <div class="fw-bold text-primary fs-5">R <%= stats ? Number(stats.totalSpent).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></div>
        </div>
        <div class="col-md-4">
          <small class="text-muted">Remaining</small>
          <div class="fw-bold text-<%= stats && (stats.budget - stats.totalSpent) < 0 ? 'danger' : 'success' %> fs-5">
            R <%= stats ? Number(stats.budget - stats.totalSpent).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 📊 Quick Stats -->
  <div class="row mb-4 g-3">
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-primary text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-money-bill-wave"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Total Spent</h6>
              <h3 class="mb-0">R <%= stats ? Number(stats.totalSpent).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-success text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-receipt"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Receipts</h6>
              <h3 class="mb-0"><%= stats ? stats.receiptCount : 0 %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-warning text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-tags"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Top Category</h6>
              <h3 class="mb-0"><%= stats ? stats.topCategory : "N/A" %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <!-- <div class="card stats-card bg-info text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-chart-pie"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Categories</h6>
              <h3 class="mb-0"><%= categoryTotals ? Object.keys(categoryTotals).length : 0 %></h3>
            </div>
          </div>
        </div>
      </div>
    </div> -->
  </div>

  <!-- 📈 Charts Section -->
  <div class="row mb-4 g-3">
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white border-0">
          <h5 class="card-title mb-0"><i class="fas fa-chart-pie text-primary me-2"></i>Spending by Category</h5>
        </div>
        <div class="card-body">
          <canvas id="pieChart" height="250"></canvas>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white border-0">
          <h5 class="card-title mb-0"><i class="fas fa-chart-bar text-primary me-2"></i>Monthly Spending Trend</h5>
        </div>
        <div class="card-body">
          <canvas id="barChart" height="250"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- 🤖 AI Predictions & 📝 Complaints Section -->
  <div class="row mb-4 g-3">
    <!-- AI Predictions -->
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-gradient-primary text-white">
          <h5 class="card-title mb-0"><i class="fas fa-robot me-2"></i>AI Spending Forecast & Insights</h5>
        </div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-md-6">
              <h6 class="fw-bold mb-3 text-primary"><i class="fas fa-chart-line me-2"></i>Monthly Forecast</h6>
              <canvas id="aiPredictionChart" height="160"></canvas>
            </div>
            <div class="col-md-6">
              <h6 class="fw-bold mb-3 text-primary"><i class="fas fa-store me-2"></i>Store Predictions</h6>
              <canvas id="storeChart" height="160"></canvas>
            </div>
          </div>
          <hr class="my-4">
          <h6 class="fw-bold mb-3 text-primary"><i class="fas fa-lightbulb me-2"></i>Key Insights</h6>
          <div id="aiInsights" class="row g-2">
            <div class="col-12">
              <div class="alert alert-info mb-0">
                <i class="fas fa-sync fa-spin me-2"></i>Fetching AI insights...
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Complaints Section -->
    <!-- 📝 Complaints -->
    <div class="col-lg-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-gradient-warning text-white">
          <h5 class="card-title mb-0"><i class="fa-solid fa-comment-dots me-2"></i>Need Help?</h5>
        </div>
        <div class="card-body">
          <form id="complaintForm" action="/complaints/submit" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
              <label for="complaintSubject" class="form-label">Subject</label>
              <input type="text" class="form-control" id="complaintSubject" name="subject" placeholder="Brief description of your issue" required>
              <div class="invalid-feedback">Please provide a subject.</div>
            </div>

            <div class="mb-3">
              <label for="complaintMessage" class="form-label">Message</label>
              <textarea class="form-control" id="complaintMessage" name="message" rows="4" placeholder="Describe your issue or suggestion..." required></textarea>
              <div class="invalid-feedback">Please provide a message.</div>
            </div>

            <div class="mb-3">
              <label for="complaintPriority" class="form-label">Priority</label>
              <select class="form-select" id="complaintPriority" name="priority" required>
                <option value="">Select priority...</option>
                <option value="low">Low - Feedback</option>
                <option value="medium">Medium - Feature request</option>
                <option value="high">High - Bug report</option>
                <option value="urgent">Urgent - Cannot use the app</option>
              </select>
              <div class="invalid-feedback">Please select a priority.</div>
            </div>

            <button type="submit" class="btn btn-warning w-100">
              <i class="fa-solid fa-paper-plane me-2"></i>Submit Complaint
            </button>
          </form>
          <div class="mt-3 text-center">
            <small class="text-muted"><i class="fa-solid fa-clock me-1"></i>We respond within 24 hours</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

  <!-- 🧾 Recent Receipts -->
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-0">
      <h5 class="card-title mb-0"><i class="fas fa-history text-primary me-2"></i>Recent Receipts</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Store</th>
              <th>Date</th>
              <th>Total (R)</th>
              <th>Payment Method</th>
              <th>Items</th>
            </tr>
          </thead>
          <tbody>
            <% if (receipts && receipts.length > 0) { %>
              <% receipts.slice(0, 5).forEach(r => { %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="store-icon bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="fas fa-store"></i>
                      </div>
                      <div>
                        <strong><%= r.store_name %></strong>
                      </div>
                    </div>
                  </td>
                  <td><%= r.date ? new Date(r.date).toLocaleDateString() : 'N/A' %></td>
                  <td class="fw-bold text-primary">R <%= r.total ? Number(r.total).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : "0.00" %></td>
                  <td>
                    <span class="badge bg-secondary">
                      <i class="fas fa-credit-card me-1"></i><%= r.payment_method %>
                    </span>
                  </td>
                  <td>
                    <span class="badge bg-light text-dark">
                      <%= r.items ? r.items.length : 0 %> items
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center py-4">
                  <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
                  <p class="text-muted mb-0">No receipts uploaded yet.</p>
                  <a href="/user/receipts/upload" class="btn btn-primary mt-2">
                    <i class="fas fa-plus me-2"></i>Upload Your First Receipt
                  </a>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <% if (receipts && receipts.length > 5) { %>
        <div class="card-footer bg-white text-center">
          <a href="/user/receipts/upload" class="btn btn-outline-primary">
            View All Receipts (<%= receipts.length %>)
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>


<!-- ===========================
     ANNOUNCEMENTS MODAL (Dynamic)
=========================== -->
<div class="modal fade" id="announcementsModal" tabindex="-1" aria-labelledby="announcementsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="announcementsModalLabel">
          <i class="fas fa-bullhorn me-2"></i>Latest Announcements
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <div class="announcement-list">
          <% if (announcements && announcements.length > 0) { %>
            <% announcements.forEach(a => { %>
              <div class="announcement-item border-start border-4 border-primary px-3 py-2 mb-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h6 class="text-primary mb-0">
                    <i class="fas fa-bullhorn me-2"></i><%= a.title %>
                  </h6>
                  <span class="badge 
                    <%= a.target_scope === 'province' ? 'bg-info' 
                      : a.target_scope === 'city' ? 'bg-warning text-dark' 
                      : a.target_scope === 'specific_users' ? 'bg-secondary' 
                      : 'bg-success' %>">
                    <%= a.target_scope %>
                  </span>
                </div>
                <p class="mb-1"><%= a.message %></p>
                <small class="text-muted">Posted on <%= new Date(a.created_at).toLocaleDateString() %></small>
              </div>
            <% }) %>
          <% } else { %>
            <div class="text-center py-4">
              <i class="fas fa-bell-slash fa-3x text-muted mb-2"></i>
              <p class="text-muted">No announcements available right now.</p>
            </div>
          <% } %>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <!-- <button type="button" class="btn btn-primary">
          <i class="fas fa-bell me-2"></i>Enable Notifications
        </button> -->
      </div>
    </div>
  </div>
</div>

<!-- ===========================
     PROFILE EDIT MODAL
=========================== -->
<div class="modal fade" id="profileModal" tabindex="-1" aria-labelledby="profileModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header bg-gradient-primary text-white">
        <h5 class="modal-title" id="profileModalLabel">
          <i class="fas fa-user-edit me-2"></i>Edit Profile
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      


<!-- ===========================
     JS SCRIPTS
=========================== -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://kit.fontawesome.com/your-fontawesome-kit.js"></script>

<style>
.stats-card {
  transition: transform 0.2s ease-in-out;
}
.stats-card:hover {
  transform: translateY(-5px);
}
.stats-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
}
.bg-gradient-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
}
.bg-gradient-warning {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%) !important;
}
.store-icon {
  font-size: 0.9rem;
}
.announcement-item {
  background: #f8f9fa;
  border-radius: 0.375rem;
}
</style>

<script>
  // ✅ Spending by Category (Pie)
  const categoryTotals = <%- categoryTotals %>;
  if (Object.keys(categoryTotals).length > 0) {
    new Chart(document.getElementById("pieChart"), {
      type: "doughnut",
      data: {
        labels: Object.keys(categoryTotals),
        datasets: [{
          data: Object.values(categoryTotals).map(v => Number(v).toFixed(2)),
          backgroundColor: [
            "#4f46e5", "#10b981", "#ef4444", "#f59e0b",
            "#8b5cf6", "#06b6d4", "#ec4899", "#84cc16",
            "#f97316", "#6366f1"
          ],
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: { 
        responsive: true, 
        plugins: { 
          legend: { 
            position: 'bottom',
            labels: { padding: 20 }
          } 
        },
        cutout: '60%'
      }
    });
  }

  // ✅ Monthly Spending (Bar)
  const monthlyData = <%- monthlySpending %>;
  if (monthlyData && monthlyData.length > 0) {
    const labels = monthlyData.map(m => {
      const date = new Date(m.month + '-01');
      return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    });
    const values = monthlyData.map(m => Number(m.total));
    
    new Chart(document.getElementById("barChart"), {
      type: "bar",
      data: {
        labels,
        datasets: [{
          label: "Total Spending (R)",
          data: values,
          backgroundColor: "#4f46e5",
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: { 
        responsive: true, 
        plugins: { 
          legend: { display: false } 
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: function(value) {
                return 'R ' + value.toLocaleString();
              }
            }
          }
        }
      }
    });
  }

  // 🤖 Load AI Predictions
  (async () => {
    const insightsEl = document.getElementById("aiInsights");
    try {
      const res = await fetch('/user/ai-predictions');
      if (!res.ok) throw new Error('Server error');
      const data = await res.json();

      // Monthly Forecast Chart
      new Chart(document.getElementById("aiPredictionChart"), {
        type: "line",
        data: {
          labels: data.monthlyForecast.map(m => {
            const date = new Date(m.month + '-01');
            return date.toLocaleDateString('en-US', { month: 'short' });
          }),
          datasets: [{
            label: "Predicted Spending",
            data: data.monthlyForecast.map(m => m.total_spent),
            borderColor: "#4f46e5",
            backgroundColor: "rgba(79, 70, 229, 0.1)",
            fill: true,
            tension: 0.4,
            borderWidth: 3
          }]
        },
        options: { 
          responsive: true,
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: function(value) {
                  return 'R ' + value;
                }
              }
            }
          }
        }
      });

      // Store Predictions Chart
      new Chart(document.getElementById("storeChart"), {
        type: "bar",
        data: {
          labels: data.storeForecast.map(s => s.store),
          datasets: [{
            label: "Predicted Spend (R)",
            data: data.storeForecast.map(s => s.predicted_spent),
            backgroundColor: ["#4f46e5", "#10b981", "#ef4444", "#f59e0b", "#8b5cf6"],
            borderRadius: 6
          }]
        },
        options: { 
          responsive: true,
          indexAxis: 'y',
          plugins: {
            legend: { display: false }
          }
        }
      });

      // Insights
      insightsEl.innerHTML = '';
      data.insights.forEach((i, index) => {
        const col = document.createElement('div');
        col.className = 'col-md-6';
        col.innerHTML = `
          <div class="alert alert-light border d-flex align-items-start">
            <i class="fas fa-lightbulb text-warning mt-1 me-3"></i>
            <div class="flex-grow-1">
              <small class="text-muted mb-0">${i}</small>
            </div>
          </div>
        `;
        insightsEl.appendChild(col);
      });

    } catch (err) {
      console.error("AI Prediction Error:", err);
      insightsEl.innerHTML = `
        <div class="col-12">
          <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle me-2"></i>
            Unable to load AI predictions at the moment. Please try again later.
          </div>
        </div>
      `;
    }
  })();

  
</script>

</body>
</html>