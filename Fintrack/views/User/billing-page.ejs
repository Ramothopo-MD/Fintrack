<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title: 'Billing & Subscription - FinTrack' }) %>
<body class="bg-light">

  <!-- Navbar + Sidebar -->
  <%- include('../partials/navbar') %>
  <%- include('../partials/sidebar') %>

  <!-- Header -->
  <section class="bg-primary text-white text-center py-4 shadow-sm">
    <div class="container">
      <h2 class="fw-bold mb-1">Billing & Subscription</h2>
      <p class="mb-0">Manage your plan, monitor usage, and view your subscription history.</p>
    </div>
  </section>

  <main class="container my-5">
    <div class="row g-4">
      <!-- Left: Current Plan -->
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <% if (activeSubscription) { 
              const used = Number(activeSubscription.requests_used || 0);
              const total = Number(activeSubscription.request_limit || 0);
              const pct = total > 0 ? Math.min(100, Math.round((used / total) * 100)) : 0;
              const s = String(activeSubscription.status || '').toLowerCase();
              const badge = (s === 'active') ? 'bg-success'
                           : (s === 'trial') ? 'bg-warning text-dark'
                           : (s === 'canceled') ? 'bg-danger'
                           : (s === 'expired') ? 'bg-secondary'
                           : 'bg-secondary';
            %>

            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between">
              <div>
                <h5 class="fw-bold mb-1">
                  <i class="bi bi-lightning-charge text-warning"></i> <%= activeSubscription.plan_name %>
                </h5>
                <div class="d-flex flex-wrap align-items-center gap-2">
                  <span class="badge <%= badge %> text-uppercase"><%= activeSubscription.status %></span>
                  <span class="text-muted small">Valid until <strong><%= activeSubscription.end_date %></strong></span>
                </div>
              </div>
              <div class="text-md-end mt-3 mt-md-0">
                <div class="fs-4 fw-bold text-primary">R<%= Number(activeSubscription.price || 0).toFixed(2) %></div>
                <div class="text-muted small">per <%= activeSubscription.billing_cycle %></div>
              </div>
            </div>

            <hr class="my-4">

            <!-- Usage -->
            <div>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-semibold">Usage</span>
                <span class="text-muted small">
                  <strong><%= used %></strong> / <%= total %> requests
                </span>
              </div>
              <div class="progress" style="height: 14px;">
                <div class="progress-bar progress-bar-striped bg-primary" style="width: <%= pct %>%;">
                  <%= pct %>%
                </div>
              </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-4">
              <button type="button" class="btn btn-outline-danger" onclick="cancelSubscription()">
                <i class="bi bi-x-circle me-1"></i> Cancel Subscription
              </button>
            </div>

            <% } else { %>
              <div class="text-center py-4">
                <h5 class="fw-bold mb-2">No Active Subscription</h5>
                <p class="text-muted">You don’t have an active plan. Choose one to get started.</p>
                <a href="/plans/billing" class="btn btn-primary">
                  <i class="bi bi-bag-check me-1"></i> Browse Plans
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Right: Available Plans -->
      <div class="col-lg-4">
        <% if (availablePlans && availablePlans.length) { %>
          <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
              <h6 class="text-uppercase text-muted mb-3">Available Plans</h6>
              <% availablePlans.forEach(p => { %>
                <div class="border rounded-3 p-3 mb-3 bg-light">
                  <div class="d-flex justify-content-between align-items-start">
                    <div>
                      <div class="fw-bold text-dark"><%= p.name %></div>
                      <div class="text-muted small mb-1"><%= p.description || '—' %></div>
                    </div>
                    <div class="text-end">
                      <div class="fw-bold text-success">R<%= Number(p.price || 0).toFixed(2) %></div>
                      <div class="text-muted small">/<%= p.billing_cycle %></div>
                    </div>
                  </div>
                  <div class="d-grid mt-3">
                    <button class="btn btn-success" onclick="upgradePlan(<%= p.plan_id %>)">
                      <i class="bi bi-credit-card me-1"></i> Upgrade
                    </button>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Subscription History -->
    <div class="row g-4 mt-4">
      <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <h6 class="text-uppercase text-muted mb-3">Subscription History</h6>
            <div class="table-responsive">
              <table class="table align-middle table-hover">
                <thead class="table-light">
                  <tr>
                    <th>Plan</th>
                    <th>Status</th>
                    <th>Start</th>
                    <th>End</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (subscriptionHistory && subscriptionHistory.length) { %>
                    <% subscriptionHistory.forEach(sub => { 
                      const st = String(sub.status || '').toLowerCase();
                      const badge = (st === 'active') ? 'bg-success'
                                   : (st === 'trial') ? 'bg-warning text-dark'
                                   : (st === 'canceled') ? 'bg-danger'
                                   : (st === 'expired') ? 'bg-secondary'
                                   : 'bg-secondary';
                    %>
                      <tr>
                        <td class="fw-semibold"><%= sub.plan_name %></td>
                        <td><span class="badge <%= badge %>"><%= sub.status %></span></td>
                        <td><%= sub.start_date %></td>
                        <td><%= sub.end_date %></td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr><td colspan="4" class="text-center text-muted py-3">No history yet.</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>

  <!-- Hidden Upgrade Form (for redirecting to Paystack) -->
  <form id="upgradeForm" action="/plans/billing/update" method="POST">
    <input type="hidden" name="planId" id="planIdField">
  </form>

  <!-- Spinner -->
  <div id="loadingSpinner" class="d-none text-center my-4">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
      <span class="visually-hidden">Processing...</span>
    </div>
    <p class="mt-2 text-muted fw-semibold">Processing your request... please wait</p>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const spinner = document.getElementById('loadingSpinner');

    async function cancelSubscription() {
      if (!confirm('Are you sure you want to cancel your subscription?')) return;
      try {
        spinner.classList.remove('d-none');
        const res = await fetch('/plans/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        if (res.ok) {
          alert('Subscription cancelled successfully!');
          location.reload();
        } else {
          alert('Failed to cancel subscription.');
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred while cancelling.');
      } finally {
        spinner.classList.add('d-none');
      }
    }

    // ✅ Upgrade plan using form submit (redirects correctly to Paystack)
    function upgradePlan(planId) {
      spinner.classList.remove('d-none');
      document.getElementById('planIdField').value = planId;
      document.getElementById('upgradeForm').submit();
    }
  </script>
</body>
</html>
