<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: 'Budget Planning - FinTrack' }) %>
<body class="bg-light">

<%- include('../partials/navbar') %>
<%- include('../partials/sidebar') %>

<!-- Main Content -->
<div class="container-fluid py-4">
  <!-- Page Header -->
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center">
        <div>
          <h2 class="fw-bold text-primary mb-1">💰 Budget Planning</h2>
          <p class="text-muted mb-0">Manage your income, set budgets, and track your spending</p>
        </div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#incomeModal">
            <i class="fas fa-plus-circle me-2"></i> Add Income
          </button>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#budgetModal">
            <i class="fas fa-chart-pie me-2"></i> 
            <%= generalBudget ? "Edit Budget" : "Set Budget" %>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ✅ Alerts -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
      <i class="fas fa-exclamation-triangle me-2"></i>
      <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
      <i class="fas fa-check-circle me-2"></i>
      <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Financial Overview Cards -->
  <div class="row mb-4 g-3">
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-primary text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-money-bill-wave"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Total Income</h6>
              <h3 class="mb-0">R <%= income && income.length > 0 ? income.reduce((sum, i) => sum + Number(i.amount), 0).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-success text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-chart-line"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Total Budget</h6>
              <h3 class="mb-0">R <%= generalBudget ? Number(generalBudget.amount).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-info text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-wallet"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Available Balance</h6>
              <h3 class="mb-0">R <%= balance ? Number(balance).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-3 col-md-6">
      <div class="card stats-card bg-warning text-white shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex align-items-center">
            <div class="stats-icon me-3">
              <i class="fas fa-receipt"></i>
            </div>
            <div>
              <h6 class="card-title mb-1">Income Sources</h6>
              <h3 class="mb-0"><%= income ? income.length : 0 %></h3>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Income Section -->
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-gradient-info text-white d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0"><i class="fas fa-money-bill-trend-up me-2"></i>Income Sources</h5>
          <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#incomeModal">
            <i class="fas fa-plus me-1"></i> Add
          </button>
        </div>
        <div class="card-body">
          <% if (income && income.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th>Source</th>
                    <th>Amount</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% 
                  // Define icon mapping directly in EJS
                  const iconMap = {
                    'Salary': 'briefcase',
                    'Freelance': 'laptop-code',
                    'Investment': 'chart-line',
                    'Business': 'building',
                    'Government funding': 'landmark',
                    'Rental': 'house',
                    'Other': 'search-dollar'
                  };
                  
                  income.forEach(i => { 
                    const icon = iconMap[i.source] || 'money-bill';
                  %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <div class="income-icon bg-info text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                            <i class="fas fa-<%= icon %>"></i>
                          </div>
                          <div>
                            <strong><%= i.source %></strong>
                          </div>
                        </div>
                      </td>
                      <td class="fw-bold text-success">R <%= Number(i.amount).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %></td>
                      <td>
                        <form method="POST" action="/manage-income/delete-income/<%= i.income_id %>?_method=DELETE" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this income source?')">
                            <i class="fas fa-trash">Delete</i>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="mt-3 p-3 bg-light rounded">
              <div class="d-flex justify-content-between align-items-center">
                <strong>Total Monthly Income:</strong>
                <span class="fw-bold text-success fs-5">
                  R <%= income.reduce((sum, i) => sum + Number(i.amount), 0).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %>
                </span>
              </div>
            </div>
          <% } else { %>
            <div class="text-center py-4">
              <i class="fas fa-money-bill-wave fa-3x text-muted mb-3"></i>
              <p class="text-muted mb-3">No income sources added yet.</p>
              <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#incomeModal">
                <i class="fas fa-plus me-2"></i>Add Your First Income Source
              </button>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Budget Section -->
    <div class="col-lg-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-gradient-success text-white d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0"><i class="fas fa-chart-pie me-2"></i>Monthly Budget</h5>
          <button class="btn btn-light btn-sm" data-bs-toggle="modal" data-bs-target="#budgetModal">
            <i class="fas fa-<%= generalBudget ? 'edit' : 'plus' %> me-1"></i> 
            <%= generalBudget ? "Edit" : "Add" %>
          </button>
        </div>
        <div class="card-body">
          <% if (generalBudget) { %>
            <div class="text-center mb-4">
              <div class="budget-circle mx-auto mb-3">
                <div class="circle-progress" data-value="<%= balance && income && income.length > 0 ? ((Number(generalBudget.amount) / income.reduce((sum, i) => sum + Number(i.amount), 0)) * 100) : 0 %>">
                  <span class="progress-value">
                    <%= balance && income && income.length > 0 ? Math.round((Number(generalBudget.amount) / income.reduce((sum, i) => sum + Number(i.amount), 0)) * 100) : 0 %>%
                  </span>
                </div>
              </div>
              <h3 class="text-success fw-bold">R <%= Number(generalBudget.amount).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %></h3>
              <p class="text-muted"><%= generalBudget.period %> Budget</p>
            </div>

            <div class="budget-info">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span>Income Allocated:</span>
                <strong class="text-success">
                  <%= balance && income && income.length > 0 ? Math.round((Number(generalBudget.amount) / income.reduce((sum, i) => sum + Number(i.amount), 0)) * 100) : 0 %>%
                </strong>
              </div>
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span>Remaining for Savings:</span>
                <strong class="text-info">R <%= balance ? Number(balance).toLocaleString('en-ZA', {minimumFractionDigits: 2}) : '0.00' %></strong>
              </div>
            </div>

            <div class="d-flex gap-2 flex-wrap mt-4">
              <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#budgetModal">
                <i class="fas fa-edit me-1"></i> Edit Budget
              </button>
              <form method="POST" action="/budget/<%= generalBudget.budget_id %>?_method=DELETE" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete your budget?')">
                  <i class="fas fa-trash me-1"></i> Delete
                </button>
              </form>
            </div>
          <% } else { %>
            <div class="text-center py-4">
              <i class="fas fa-chart-pie fa-3x text-muted mb-3"></i>
              <p class="text-muted mb-3">No budget set yet. Set a budget to start tracking your expenses effectively.</p>
              <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#budgetModal">
                <i class="fas fa-plus me-2"></i>Set Your Budget
              </button>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Budget vs Spending vs Income Chart -->
  <div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-white border-0">
      <h5 class="card-title mb-0"><i class="fas fa-chart-bar text-primary me-2"></i>Financial Overview</h5>
    </div>
    <div class="card-body">
      <div style="height: 400px;">
        <canvas id="budgetChart"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- Income Modal -->
<div class="modal fade" id="incomeModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow-lg border-0">
      <div class="modal-header bg-gradient-primary text-white">
        <h5 class="modal-title"><i class="fas fa-money-bill-wave me-2"></i>Add Income Source</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/manage-income/save-income">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Income Amount (R)</label>
            <input type="number" class="form-control form-control-lg" name="amount" required 
                   placeholder="e.g. 15000" min="0" step="0.01">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Source of Income</label>
            <select class="form-select form-select-lg" name="source" required>
              <option value="" disabled selected>Select Income Source</option>
              <option value="Salary">💰 Salary</option>
              <option value="Freelance">💼 Freelance</option>
              <option value="Investment">📈 Investment</option>
              <option value="Business">🏢 Business</option>
              <option value="Government funding">🏛️ Government Funding</option>
              <option value="Rental">🏠 Rental Income</option>
              <option value="Other">🔍 Other</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary px-4">
            <i class="fas fa-save me-2"></i>Save Income
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Budget Modal -->
<div class="modal fade" id="budgetModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow-lg border-0">
      <div class="modal-header bg-gradient-success text-white">
        <h5 class="modal-title">
          <i class="fas fa-<%= generalBudget ? 'edit' : 'plus-circle' %> me-2"></i>
          <%= generalBudget ? 'Edit Budget' : 'Set Monthly Budget' %>
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="<%= generalBudget ? '/budget/' + generalBudget.budget_id + '?_method=PUT' : '/budget' %>">
        <div class="modal-body">
          <input type="hidden" name="name" value="General Budget">
          <input type="hidden" name="type" value="GENERAL">

          <div class="mb-3">
            <label class="form-label fw-semibold">Budget Amount (R)</label>
            <input type="number" name="amount" class="form-control form-control-lg"
                   required placeholder="e.g. 5000"
                   value="<%= generalBudget ? generalBudget.amount : '' %>"
                   min="0" step="0.01">
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Budget Period</label>
            <select name="period" class="form-select form-select-lg" required>
              <option value="" disabled <%= !generalBudget ? 'selected' : '' %>>Select Period</option>
              <option value="MONTHLY" <%= generalBudget && generalBudget.period === 'MONTHLY' ? 'selected' : '' %>>📅 Monthly</option>
              <option value="WEEKLY" <%= generalBudget && generalBudget.period === 'WEEKLY' ? 'selected' : '' %>>📆 Weekly</option>
              <option value="YEARLY" <%= generalBudget && generalBudget.period === 'YEARLY' ? 'selected' : '' %>>📊 Yearly</option>
            </select>
          </div>

          <% if (income && income.length > 0) { %>
            <div class="alert alert-info">
              <i class="fas fa-info-circle me-2"></i>
              Your total income is <strong>R <%= income.reduce((sum, i) => sum + Number(i.amount), 0).toLocaleString('en-ZA', {minimumFractionDigits: 2}) %></strong>
            </div>
          <% } %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success px-4">
            <i class="fas fa-<%= generalBudget ? 'save' : 'check' %> me-2"></i>
            <%= generalBudget ? 'Update Budget' : 'Set Budget' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
.stats-card {
  transition: transform 0.2s ease-in-out;
}
.stats-card:hover {
  transform: translateY(-5px);
}
.stats-icon {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
}
.bg-gradient-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
}
.bg-gradient-success {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%) !important;
}
.bg-gradient-info {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%) !important;
}
.income-icon {
  font-size: 0.9rem;
}
.budget-circle {
  width: 120px;
  height: 120px;
  position: relative;
}
.circle-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: conic-gradient(#10b981 var(--progress), #e5e7eb 0deg);
  display: flex;
  align-items: center;
  justify-content: center;
}
.circle-progress::before {
  content: '';
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: white;
  position: absolute;
}
.progress-value {
  position: relative;
  font-weight: bold;
  color: #10b981;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  // Set up circular progress
  const circleProgress = document.querySelector('.circle-progress');
  if (circleProgress) {
    const progressValue = circleProgress.getAttribute('data-value');
    circleProgress.style.setProperty('--progress', `${progressValue}%`);
  }

  // Budget Chart
  const ctx = document.getElementById("budgetChart").getContext("2d");
  
  const totalIncome = <%= income && income.length > 0 ? income.reduce((sum, i) => sum + Number(i.amount), 0) : 0 %>;
  const totalBudget = <%= generalBudget ? Number(generalBudget.amount) : 0 %>;
  const totalSpent = <%= categoryBudgets ? categoryBudgets.reduce((sum, b) => sum + (Number(b.amount) || 0), 0) : 0 %>;
  const availableBalance = totalIncome - totalBudget;

  new Chart(ctx, {
    type: "bar",
    data: {
      labels: ["Total Income", "Monthly Budget", "Available Balance", "Total Allocated"],
      datasets: [
        { 
          label: "Amount (R)", 
          data: [totalIncome, totalBudget, availableBalance, totalSpent], 
          backgroundColor: ["#10b981", "#3b82f6", "#8b5cf6", "#f59e0b"],
          borderRadius: 8,
          borderWidth: 0
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: function(context) {
              return `R ${context.raw.toLocaleString('en-ZA', {minimumFractionDigits: 2})}`;
            }
          }
        }
      },
      scales: {
        y: { 
          beginAtZero: true,
          ticks: {
            callback: function(value) {
              return 'R ' + value.toLocaleString();
            }
          }
        }
      }
    }
  });
});
</script>

</body>
</html>